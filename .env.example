APP_NAME="SAGANSA CEISA API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Default DB: sagansa_ceisa (dedicated PIB/NOTUL data — separate from sagansa)
DB_CONNECTION=mysql_ceisa
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=

# sagansa_ceisa — dedicated DB for CEISA data
DB_CEISA_HOST=127.0.0.1
DB_CEISA_PORT=3306
DB_CEISA_DATABASE=sagansa_ceisa
DB_CEISA_USERNAME=root
DB_CEISA_PASSWORD=

# sagansa_user (auth — read only, do NOT modify schema)
DB_AUTH_HOST=127.0.0.1
DB_AUTH_PORT=3306
DB_AUTH_DATABASE=sagansa_user
DB_AUTH_USERNAME=root
DB_AUTH_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=file

# Redis (Queue + Horizon)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============ CEISA 4.0 Gateway ============
# Credentials stored encrypted in DB (ceisa_credentials), these are fallbacks/defaults:
CEISA_GATEWAY_MODE=sandbox
CEISA_GATEWAY_SANDBOX=https://apisdev-gw.beacukai.go.id
CEISA_GATEWAY_PRODUCTION=
CEISA_APPLICATION_ID=
CEISA_API_KEY=
CEISA_WEBHOOK_URL=https://api-ceisa.sagansa.id/v1/ceisa-webhook
# Optional shared secret for verifying inbound webhook signatures:
CEISA_WEBHOOK_SECRET=
# HTTP client tuning
CEISA_HTTP_TIMEOUT=30
CEISA_CONNECT_TIMEOUT=10
CEISA_SUBMIT_TRIES=3
CEISA_SUBMIT_BACKOFF=300
# Path yang di-hit untuk test koneksi gateway (WAJIB path API nyata, bukan '/')
CEISA_TEST_PATH=/v1/pib/submit

# Mock mode: set true untuk testing lokal tanpa gateway BC (synthetic responses)
CEISA_MOCK_ENABLED=false
# Endpoint PIB (verifikasi via OpenAPI Portal BEA CUKAI; update saat real endpoint diketahui)
CEISA_PIB_SUBMIT_PATH=/v1/pib/submit
CEISA_PIB_STATUS_PATH=/v1/pib/{aju}/status

# ============ FCM (Firebase) — Fase 5 ============
FCM_SERVER_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# ============ Telegram Bot — Fase 5 ============
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============ Email (SMTP) — Fase 5 ============
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@sagansa.id
MAIL_FROM_NAME="${APP_NAME}"